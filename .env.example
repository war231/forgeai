# ============================================
# NovelForge Kit 配置文件模板
# ============================================
# 复制此文件为 .env 并填写你的配置值

# ============================================
# 创作大模型（必需）
# ============================================
# 服务商标识：openai / deepseek / qwen / kimi / claude
LLM_PROVIDER=openai

# 模型名称
LLM_MODEL=gpt-4o-mini

# API 密钥
LLM_API_KEY=sk-xxx

# API 端点（可选，根据服务商填写）
LLM_BASE_URL=https://api.openai.com/v1


# ============================================
# 创作参数（可选 - 有默认值）
# ============================================
# 默认温度（0-2，越高越随机）
LLM_TEMPERATURE=0.7

# 核采样参数
LLM_TOP_P=0.9

# 最大输出 tokens
LLM_MAX_TOKENS=4096

# 上下文窗口限制
LLM_MAX_CONTEXT_TOKENS=128000
LLM_RESERVE_TOKENS=4096

# 环节特定温度
LLM_TEMPERATURE_OUTLINE=0.4   # 大纲：严谨
LLM_TEMPERATURE_WRITING=1.0   # 正文：发散
LLM_TEMPERATURE_REVIEW=0.3    # 审查：严谨


# ============================================
# Embedding 模型（必需）
# ============================================

# === 选项1：OpenAI ===
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_MODEL=text-embedding-3-small
EMBED_API_KEY=sk-xxx

# === 选项2：SiliconFlow（推荐，支持 Qwen3） ===
# EMBED_BASE_URL=https://api.siliconflow.cn/v1
# EMBED_MODEL=Qwen/Qwen3-Embedding-8B
# EMBED_API_KEY=sk-xxx

# === 选项3：阿里云 DashScope ===
# EMBED_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# EMBED_MODEL=text-embedding-v3
# EMBED_API_KEY=sk-xxx

# 向量维度（可选）
EMBED_DIMENSION=1536


# ============================================
# Reranker 模型（可选）
# ============================================

# === 选项1：阿里云 DashScope（推荐） ===
RERANK_PROVIDER=qwen
RERANK_API_KEY=sk-xxx
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1
RERANK_MODEL=qwen3-rerank

# === 选项2：Jina AI ===
# RERANK_PROVIDER=jina
# RERANK_API_KEY=sk-xxx
# RERANK_BASE_URL=https://api.jina.ai/v1
# RERANK_MODEL=jina-reranker-v2


# ============================================
# 日志配置（可选）
# ============================================
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 日志文件路径（留空则不写文件）
LOG_FILE=


# ============================================
# 提供商特定配置（可选）
# ============================================
# 文心一言需要两个密钥
# ERNIE_API_KEY=xxx
# ERNIE_SECRET_KEY=xxx

# Claude（如果使用 Claude 且未设置 LLM_API_KEY）
# ANTHROPIC_API_KEY=sk-xxx


# ============================================
# API Key 申请地址
# ============================================
# OpenAI: https://platform.openai.com
# DeepSeek: https://platform.deepseek.com
# 通义千问/DashScope: https://dashscope.aliyun.com
# SiliconFlow: https://siliconflow.cn
# Jina AI: https://jina.ai
# Claude: https://anthropic.com
# 文心一言: https://console.bce.baidu.com/qianfan
